# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=codeclinic
POSTGRES_PASSWORD=codeclinic_dev
POSTGRES_DB=codeclinic
DATABASE_URL=postgresql://codeclinic:codeclinic_dev@localhost:5432/codeclinic

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64char_secret
JWT_REFRESH_SECRET=change_me_to_a_different_random_64char_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=change_me_to_32_byte_hex_string_for_aes256  # AES-256 medical notes

# ─── App ─────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NODE_ENV=development
PORT=4000

# ─── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── ElevenLabs (Voice) ──────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...  # Default agent voice

# ─── Africa's Talking (Voice / WhatsApp / SMS) ────────────────
AFRICAS_TALKING_API_KEY=...
AFRICAS_TALKING_USERNAME=...
AFRICAS_TALKING_FROM_NUMBER=+256...

# ─── Cloudflare R2 (Storage) ─────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET=codeclinic
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Pesapal (Payments) ──────────────────────────────────────
PESAPAL_CONSUMER_KEY=...
PESAPAL_CONSUMER_SECRET=...
PESAPAL_ENV=sandbox  # or live

# ─── Google APIs ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_SHEETS_SPREADSHEET_ID=...
GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=...
GMAIL_USER=...

# ─── SMTP (Employee Credentials Email) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@codeclinic.ug
SMTP_PASS=...
SMTP_FROM="Code Clinic <noreply@codeclinic.ug>"

# ─── OpenWeather (Kampala weather widget) ────────────────────
OPENWEATHER_API_KEY=...
OPENWEATHER_CITY=Kampala
OPENWEATHER_UNITS=metric

# ─── Next.js Public ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=CodeClinic
NEXT_PUBLIC_CLINIC_NAME="Code Clinic"
NEXT_PUBLIC_CLINIC_PHONE=+256700000000
NEXT_PUBLIC_CLINIC_EMAIL=info@codeclinic.ug
NEXT_PUBLIC_GOOGLE_MAPS_KEY=...
