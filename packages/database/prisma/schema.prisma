generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS — PostgreSQL native enum types
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
  ACCOUNTS
  DEVELOPER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  ARRIVED
  WAITING
  IN_OPERATORY
  WITH_PROVIDER
  SESSION_COMPLETE
  CHECKOUT
  DEPARTED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
  CHECKED_IN
  IN_CHAIR
  READY_CHECKOUT
  IMPORTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  UNPAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum ConversationStatus {
  ACTIVE
  HUMAN_TAKEOVER
  CLOSED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientStatus {
  NEW_LEAD
  UPCOMING
  ACTIVE
  DUE_RECALL
  LAPSED
  DORMANT
  BALANCE_OWING
}

// ─────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  role              UserRole  @default(RECEPTIONIST)
  firstName         String
  lastName          String
  phone             String?
  avatarR2Key       String?
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  isActive          Boolean   @default(true)
  lastLogin         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  doctor            Doctor?
  auditLogs         AuditLog[]
  assistantMessages AssistantMessage[]
  supportTickets    SupportTicket[]
  expenses          Expense[]      @relation("RecordedBy")
  payroll           StaffPayroll[]
  appointments      Appointment[]  @relation("CreatedBy")
  treatmentNotes    TreatmentNote[]

  @@index([isActive])
  @@map("users")
}

model Doctor {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialisation String?
  colour         String   @default("#4A90D9")
  photoR2Key     String?
  workingDays    String   @default("[1,2,3,4,5]")
  workingHours   String   @default("{\"start\":\"08:00\",\"end\":\"18:00\"}")
  serviceIds     String   @default("[]")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments   Appointment[]
  blockedTimes   BlockedTime[]
  schedules      DoctorSchedule[]

  @@map("doctors")
}

model BlockedTime {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@map("blocked_times")
}

model WorkingHours {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Sun, 1=Mon ... 6=Sat
  isOpen    Boolean  @default(true)
  openTime  String
  closeTime String
  breaks    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
  @@map("working_hours")
}

model DoctorSchedule {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  isOpen    Boolean  @default(true)
  openTime  String?
  closeTime String?
  breaks    Json?
  slots     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, dayOfWeek])
  @@map("doctor_schedules")
}

model SpecialDay {
  id        String   @id @default(cuid())
  date      DateTime @unique
  type      String   // "DAY_OFF" | "SPECIAL_WORKING"
  openTime  String?
  closeTime String?
  note      String?
  createdAt DateTime @default(now())

  @@map("special_days")
}

model Patient {
  id                    String   @id @default(uuid())
  patientNumber         Int      @default(autoincrement())
  firstName             String
  lastName              String
  phone                 String
  email                 String?
  dob                   DateTime?
  gender                Gender?
  address               String?
  district              String?
  medicalNotesEncrypted String?
  avatarR2Key           String?
  accountBalance        Int      @default(0)
  isActive              Boolean  @default(true)
  referredBy            String?
  referralSource        String?
  nextOfKinName         String?
  nextOfKinPhone        String?
  nextOfKinRelation     String?
  allergies             String?
  medicalHistory        String?
  status                PatientStatus @default(NEW_LEAD)
  importSource          String?       // "SHEET" | "CSV" — set on bulk import, null for manual registrations
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  appointments          Appointment[]
  invoices              Invoice[]
  payments              Payment[]
  feedback              PatientFeedback[]
  nurtureLogs           NurtureLog[]
  agentLogs             AgentLog[]
  agentMemory           AgentMemory[]
  outboundQueue         OutboundQueue[]
  treatmentPlans        TreatmentPlan[]
  treatmentNotes        TreatmentNote[]
  dentalChart           DentalChart?
  documents             PatientDocument[]
  activities            PatientActivity[]
  aiConversations       AiConversation[]
  aiScheduledMessages   AiScheduledMessage[]

  @@index([isActive, createdAt])
  @@index([lastName, firstName])
  @@index([status])
  @@map("patients")
}

model Service {
  id             String  @id @default(uuid())
  name           String
  description    String?
  category       String  @default("General")
  durationMins   Int     @default(30)
  priceUGX       Int
  priceUSD       Float?
  vatApplicable  Boolean @default(true)
  colour         String  @default("#29ABE2")
  photoR2Key     String?
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments   Appointment[]

  @@unique([name])
  @@map("services")
}

model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  startAt     DateTime
  endAt       DateTime
  status      AppointmentStatus @default(PENDING)
  notes         String?
  googleEventId String?
  createdById   String?
  createdBy     User?    @relation("CreatedBy", fields: [createdById], references: [id])
  arrivedAt     DateTime?
  withProviderAt DateTime?
  departedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoice     Invoice?
  feedback    PatientFeedback?

  @@index([doctorId, startAt])
  @@index([patientId, startAt])
  @@index([status, startAt])
  @@map("appointments")
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  lineItems     String   // JSON string
  subtotalUGX   Int
  vatUGX        Int      @default(0)
  totalUGX      Int
  paidUGX       Int           @default(0)
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  notes         String?
  // QuickBooks sync
  qbInvoiceId   String?
  qbCustomerId  String?
  qbSyncStatus  String?   // PENDING | SYNCED | FAILED
  qbSyncedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payments      Payment[]

  @@index([patientId, status])
  @@index([status, dueDate])
  @@map("invoices")
}

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  amountUGX   Int
  method      String   // CASH | MTN_MOMO | AIRTEL_MONEY | VISA | MASTERCARD | etc
  reference   String?
  paidAt      DateTime @default(now())
  notes       String?
  qbPaymentId String?  // QuickBooks payment ID
  createdAt   DateTime @default(now())

  @@map("payments")
}

model Expense {
  id           String   @id @default(uuid())
  category     String
  amountUGX    Int
  description  String
  receiptR2Key String?
  recordedById String?
  recordedBy   User?    @relation("RecordedBy", fields: [recordedById], references: [id])
  date         DateTime @default(now())
  qbPurchaseId String?  // QuickBooks purchase ID
  createdAt    DateTime @default(now())

  @@map("expenses")
}

model StaffPayroll {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  month           String
  grossUGX        Int
  nssfEmployee    Int
  nssfEmployer    Int
  paye            Int
  otherDeductions Int      @default(0)
  netUGX          Int
  status          String   @default("PENDING")
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  @@unique([userId, month])
  @@map("staff_payroll")
}

model Lead {
  id          String   @id @default(cuid())
  name        String?
  phone       String?
  email       String?
  source      String   // WHATSAPP, FACEBOOK, WEBSITE, INSTAGRAM, WALKIN, OTHER
  stage       String   @default("NEW")   // kept for quiz/nurture compat
  status      String   @default("NEW")   // NEW, CONTACTED, QUALIFIED, CONVERTED, LOST
  score       Int      @default(0)
  assignedTo  String?
  quizId      String?
  quizAnswers String?  // JSON string
  notes       String?
  lastMessage String?
  convertedToPatientId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nurtureLogs NurtureLog[]

  @@index([source])
  @@index([status])
  @@map("leads")
}

model Quiz {
  id          String   @id @default(uuid())
  title       String
  description String?
  questions   String   // JSON string
  resultText  String   // JSON string
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quizzes")
}

model QRCapture {
  id         String   @id @default(uuid())
  name       String
  formConfig String   // JSON string
  destination String  @default("CRM")
  qrCodeData String?
  scanCount  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("qr_captures")
}

model WebsiteVisitor {
  id            String   @id @default(uuid())
  sessionId     String   @unique
  page          String?
  ip            String?
  userAgent     String?
  capturedEmail String?
  capturedName  String?
  agentEngaged  Boolean  @default(false)
  agentLogId    String?
  createdAt     DateTime @default(now())

  @@map("website_visitors")
}

model Campaign {
  id              String   @id @default(uuid())
  type            String
  name            String
  channel         String   @default("WHATSAPP")
  messageTemplate String
  targetSegment   String?  // JSON string
  scheduledAt     DateTime?
  status          String   @default("DRAFT")
  sentCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  nurtureLogs NurtureLog[]

  @@map("campaigns")
}

model NurtureLog {
  id          String   @id @default(uuid())
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  channel     String
  message     String
  status      String   @default("QUEUED")
  sentAt      DateTime?
  deliveredAt DateTime?
  externalId  String?
  createdAt   DateTime @default(now())

  @@map("nurture_logs")
}

model AgentLog {
  id          String   @id @default(uuid())
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id])
  visitorId   String?
  callSid     String?
  type        String
  channel     String   @default("VOICE")
  transcript  String?
  outcome     String?
  durationSec Int?
  escalated   Boolean  @default(false)
  createdAt   DateTime @default(now())

  recording   CallRecording?

  @@map("agent_logs")
}

model CallRecording {
  id             String   @id @default(uuid())
  agentLogId     String   @unique
  agentLog       AgentLog @relation(fields: [agentLogId], references: [id])
  r2Key          String
  durationSec    Int?
  transcriptText String?
  qualityScore   Float?
  adminNotes     String?
  createdAt      DateTime @default(now())

  @@map("call_recordings")
}

model AgentPrompt {
  id           String   @id @default(uuid())
  type         String   @unique
  name         String
  systemPrompt String
  version      Int      @default(1)
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@map("agent_prompts")
}

model VoiceProfile {
  id                String   @id @default(uuid())
  name              String
  elevenLabsVoiceId String
  isCloned          Boolean  @default(false)
  previewR2Key      String?
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@map("voice_profiles")
}

model KnowledgeBase {
  id         String   @id @default(uuid())
  title      String
  type       String
  r2Key      String?
  sourceUrl  String?
  rawText    String?
  chunkIndex Int      @default(0)
  parentId   String?
  isActive   Boolean  @default(true)
  embedding  String?  // JSON array of floats (OpenAI text-embedding-ada-002)
  tokenCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("knowledge_base")
}

model PatientFeedback {
  id            String   @id @default(uuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  rating        Int
  comment       String?
  channel       String   @default("APP")
  submittedAt   DateTime @default(now())

  @@map("patient_feedback")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  metadata   String?  // JSON string
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model AssistantMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   // USER | ASSISTANT
  content   String
  context   String?  // JSON string
  createdAt DateTime @default(now())

  @@map("assistant_messages")
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  title       String
  description String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_tickets")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   // recipient user ID
  type      String   // ESCALATION | APPOINTMENT | CONFIRMATION | MESSAGE | SYSTEM
  title     String
  body      String
  isRead    Boolean  @default(false)
  href      String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model InternalMessage {
  id          String   @id @default(uuid())
  fromUserId  String
  toRole      String?  // ADMIN | DOCTOR | RECEPTIONIST | ACCOUNTS
  toUserId    String?
  subject     String?
  body        String
  patientTag  String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("internal_messages")
}

// ─────────────────────────────────────────────
// UNIFIED AI AGENT
// ─────────────────────────────────────────────

model AgentMemory {
  id               String   @id @default(cuid())
  patientId        String?
  patient          Patient? @relation(fields: [patientId], references: [id])
  channel          String   // VOICE | WHATSAPP
  phoneNumber      String
  interactionType  String   // INBOUND | REMINDER | FOLLOWUP | DEBT
  summary          String
  outcome          String   // BOOKED | RESCHEDULED | CANCELLED | CONFIRMED | ESCALATED | NO_ANSWER | CALLBACK_REQUESTED
  callRecordingUrl String?
  transcript       String?
  agentMode        String
  createdAt        DateTime @default(now())

  @@index([patientId])
  @@index([phoneNumber])
  @@map("agent_memory")
}

model AgentConfig {
  id                 String   @id @default(cuid())
  responsibility     String   @unique // INBOUND | REMINDER | FOLLOWUP | DEBT
  isActive           Boolean  @default(false)
  systemPrompt       String
  promptVersion      Int      @default(1)
  promptHistory      String   @default("[]") // JSON [{version, prompt, activatedAt, activatedBy}]
  scheduleCron       String?  // e.g. "0 6 * * *" (UTC for 09:00 EAT)
  maxAttempts        Int      @default(3)
  retryIntervalHours Int      @default(4)
  updatedBy          String?
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@map("agent_config")
}

model OutboundQueue {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  phoneNumber   String
  agentMode     String    // REMINDER | FOLLOWUP | DEBT
  reason        String
  appointmentId String?
  scheduledFor  DateTime
  attempts      Int       @default(0)
  lastAttempted DateTime?
  status        String    @default("PENDING") // PENDING | CALLING | COMPLETED | FAILED | ESCALATED
  outcome       String?
  createdAt     DateTime  @default(now())

  @@index([status, scheduledFor])
  @@map("outbound_queue")
}

model Escalation {
  id             String    @id @default(cuid())
  patientId      String?
  phoneNumber    String
  channel        String    // VOICE | WHATSAPP
  reason         String
  transcript     String?
  whatsappThread String?   // JSON array — full conversation
  status         String    @default("PENDING") // PENDING | HANDLED | RESOLVED
  handledBy      String?
  handledAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([status])
  @@map("escalations")
}

// ─────────────────────────────────────────────
// CLINICAL FEATURES
// ─────────────────────────────────────────────

model TreatmentPlan {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  serviceId   String?
  stage       String   @default("Consulted")
  status      String   @default("Planned")
  toothNumber String?
  quantity    Int      @default(1)
  costPerUnit Int      @default(0)
  discount    Int      @default(0)
  notes       String?
  dateAdded   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([patientId])
  @@index([stage])
  @@map("treatment_plans")
}

model TreatmentNote {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  content   String
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@map("treatment_notes")
}

model DentalChart {
  id             String   @id @default(cuid())
  patientId      String   @unique
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  teeth          String   @default("{}")
  periodontal    String   @default("{}")
  aiSummary      String?
  aiPerioSummary String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@map("dental_charts")
}

model PatientDocument {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  fileUrl    String
  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([patientId])
  @@map("patient_documents")
}

model PatientActivity {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  action    String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([patientId])
  @@map("patient_activities")
}

model DoctorCheckIn {
  id        String   @id @default(cuid())
  doctorId  String
  userId    String
  type      String   @default("CHECK_IN")
  note      String?
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())

  @@index([doctorId])
  @@map("doctor_check_ins")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─────────────────────────────────────────────
// AI SUITE — Sarah (WhatsApp / Omnichannel)
// ─────────────────────────────────────────────

model AiConversation {
  id           String   @id @default(cuid())
  patientId    String?
  patient      Patient? @relation(fields: [patientId], references: [id])
  channel      String             // WHATSAPP | SMS | VOICE | WEBSITE | FACEBOOK | INSTAGRAM
  phoneNumber  String
  status       ConversationStatus @default(ACTIVE)
  agentEnabled Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  messages     AiMessage[]

  @@index([phoneNumber])
  @@index([channel, status, phoneNumber])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // USER | AGENT | SYSTEM
  content        String
  metadata       String?        // JSON
  createdAt      DateTime       @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

model AiKnowledgeBase {
  id        String                      @id @default(cuid())
  title     String
  type      String                      // PDF | IMAGE | AUDIO | VIDEO | URL | TEXT
  content   String
  embedding Unsupported("vector")?
  sourceUrl String?
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  @@map("ai_knowledge_base")
}

model AiAgentConfig {
  id          String   @id @default(cuid())
  name        String   @default("Sarah")
  personality String
  systemPrompt        String?
  isActive            Boolean  @default(true)
  escalationPhone     String?
  escalationTriggers  String?
  waPhoneNumberId         String?
  waAccessToken           String?
  facebookPageAccessToken String?
  facebookPageName        String?
  instagramAccessToken    String?
  instagramAccountName    String?
  smsApiKey     String?
  smsUsername   String?
  smsSenderId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_agent_config")
}

model SipTrunk {
  id                 String   @id @default(cuid())
  name               String
  host               String
  port               Int      @default(5060)
  netmask            Int      @default(32)
  protocol           String   @default("UDP")
  allowInbound       Boolean  @default(true)
  allowOutbound      Boolean  @default(true)
  optionsPing        Boolean  @default(false)
  username           String?
  password           String?
  useSipRegistration Boolean  @default(false)
  leadingPlus        Boolean  @default(false)
  techPrefix         String?
  sipDiversionHeader String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("sip_trunks")
}

model AiScheduledMessage {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  channel      String
  templateType String   // REMINDER | FOLLOWUP | DEBT | LEADNURTURE
  scheduledFor DateTime
  sent         Boolean  @default(false)
  content      String
  createdAt    DateTime @default(now())

  @@index([sent, scheduledFor])
  @@map("ai_scheduled_messages")
}

model StockItem {
  id           String   @id @default(cuid())
  name         String
  category     String   @default("Other")
  quantity     Float    @default(0)
  unit         String   @default("pieces")
  reorderLevel Float    @default(10)
  unitCost     Float    @default(0)
  supplier     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("stock_items")
}
